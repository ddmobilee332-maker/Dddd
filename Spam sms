import time
import os
import random
import sys
from datetime import datetime

# พยายามโหลด colorama เพื่อความสมจริงของสีสันหน้าจอ
try:
    from colorama import Fore, Style, init
    init(autoreset=True)
except ImportError:
    class Style: RESET_ALL = ""
    class Fore: RED = ""; GREEN = ""; CYAN = ""; YELLOW = ""; MAGENTA = ""; WHITE = ""; BLUE = ""

def clear_screen():
    os.system('cls' if os.name == 'nt' else 'clear')

def glitch_text(text, speed=0.02):
    """ทำให้ตัวอักษรค่อยๆ ปรากฏเหมือนระบบกำลังถอดรหัส"""
    for char in text:
        sys.stdout.write(char)
        sys.stdout.flush()
        time.sleep(speed)

def cyber_loading(action_text, duration=1.2):
    """อนิเมชั่นโหลดข้อมูลสไตล์ไซเบอร์"""
    chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
    end_time = time.time() + duration
    i = 0
    while time.time() < end_time:
        sys.stdout.write(f"\r{Fore.YELLOW}[{chars[i % len(chars)}] กำลัง{action_text}...")
        sys.stdout.flush()
        time.sleep(0.08)
        i += 1
    sys.stdout.write(f"\r{Fore.GREEN}[✓] {action_text} - เสร็จสิ้น\n")

